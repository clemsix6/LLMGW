# LLMGW configuration. Copy this file to .env and fill in the values. The .env file is
# gitignored — never commit real secrets.

# Address the HTTP server binds to.
#   - Running the binary directly on the host: 127.0.0.1:8088 keeps it local-only.
#   - Running under docker-compose: use 0.0.0.0:8088 so the docker proxy can reach the app; the
#     compose port mapping ("127.0.0.1:8088:8088") is what enforces local-only host exposure.
LLMGW_LISTEN=0.0.0.0:8088

# Connection string for the state database. Use a SEPARATE database named "llmgw" inside the
# existing Postgres instance (run `CREATE DATABASE llmgw;` once). When Postgres runs on the docker
# host and the gateway runs in compose, use host.docker.internal as the host.
LLMGW_POSTGRES_DSN=postgres://llmgw:CHANGE_ME@host.docker.internal:5432/llmgw?sslmode=disable

# Seed claude.ai session keys, comma-separated "account_label=sessionkey" pairs. The gateway
# bootstraps Claude Code OAuth tokens from each session key on demand and re-mints them when they
# die, so a session key is the durable root credential. Seeded into oauth_token only when the
# account has no row yet (never overwritten). Multiple accounts enable round-robin + cooldown
# rotation, e.g. acct1=sk-ant-sid02-...,acct2=sk-ant-sid02-...
LLMGW_SESSION_KEYS=acct1=CHANGE_ME

# Spoofed Claude Code client version (used for the UA + cc_version billing header). Set it to the
# operator's current Claude Code version. Defaults to 2.1.181 when unset.
LLMGW_CLAUDE_CODE_VERSION=2.1.181

# Default project for requests that omit the X-Project header. Leave UNSET to require X-Project on
# every call (the strict default). Set it to make the gateway a drop-in for header-less Anthropic
# clients (e.g. a client that only knows the Messages body): such calls are attributed to this
# project instead of being rejected with a 400. An explicit X-Project header always wins.
#LLMGW_DEFAULT_PROJECT=truewallet

# Test-only: a claude.ai session key used to gate the real-API E2E suite (test/e2e). Not read by
# the gateway itself — leave it unset in production.
#LLMGW_TEST_SESSION_KEY=CHANGE_ME
